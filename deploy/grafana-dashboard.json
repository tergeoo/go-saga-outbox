{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Health and throughput of the go-saga-outbox demo. Pairs with the prometheus.yml scrape targets shipped in deploy/.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Saga lifecycle (totals)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },

    {
      "type": "stat",
      "id": 1,
      "title": "Completed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of sagas in state=completed (snapshot from DB, survives restart).",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "saga_state_count{state=\"completed\"}",
          "refId": "A",
          "legendFormat": "completed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Compensated",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of sagas in state=compensated (DB snapshot).",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "saga_state_count{state=\"compensated\"}",
          "refId": "A",
          "legendFormat": "compensated"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Failed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of sagas in state=failed (DB snapshot).",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "saga_state_count{state=\"failed\"}",
          "refId": "A",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "In flight (running + compensating)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Sagas currently in flight: running (forward) or compensating (rollback). DB snapshot.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(saga_state_count{state=~\"running|compensating\"})",
          "refId": "A",
          "legendFormat": "in flight"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 }
    },

    {
      "type": "row",
      "id": 101,
      "title": "Saga rates",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },

    {
      "type": "timeseries",
      "id": 5,
      "title": "Saga completion / compensation rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "rate(saga_*_total[1m]) — useful to see throughput and detect stalls.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(saga_completed_total[1m])",
          "refId": "A",
          "legendFormat": "completed/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(saga_compensated_total[1m])",
          "refId": "B",
          "legendFormat": "compensated/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(saga_failed_total[1m])",
          "refId": "C",
          "legendFormat": "failed/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "spanNulls": true },
          "unit": "ops"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Saga retries by step (scheduler re-publishes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "rate(saga_retries_total[1m]) broken down by current_step.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(saga_retries_total[1m])",
          "refId": "A",
          "legendFormat": "{{step}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "spanNulls": true },
          "unit": "ops"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },

    {
      "type": "row",
      "id": 102,
      "title": "Outbox backlog per service",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },

    {
      "type": "timeseries",
      "id": 7,
      "title": "Unpublished outbox messages",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current size of each service's outbox backlog. Sustained > 0 means relay is falling behind.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_unpublished_count",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Oldest unpublished message age",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Age in seconds of the oldest unpublished outbox row. 0 means outbox is drained.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_oldest_unpublished_age_seconds",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 }
    },

    {
      "type": "row",
      "id": 103,
      "title": "Reliability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },

    {
      "type": "timeseries",
      "id": 9,
      "title": "DLQ — poison messages per consumer",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "rate(dlq_messages_total[5m]) — surge here usually means malformed payloads or a regression in a handler.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(dlq_messages_total[5m])",
          "refId": "A",
          "legendFormat": "{{consumer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "spanNulls": true },
          "unit": "ops"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Inbox duplicates caught",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "rate(inbox_duplicates_total[5m]) — non-zero means Kafka redelivery is happening; persistent spikes can hint at a slow consumer.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(inbox_duplicates_total[5m])",
          "refId": "A",
          "legendFormat": "{{consumer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "spanNulls": true },
          "unit": "ops"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "DLQ unreplayed (by consumer)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of dead_message rows where replayed_at IS NULL. DB snapshot, survives restart.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "dlq_unreplayed_count",
          "refId": "A",
          "legendFormat": "{{consumer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto"
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 32 }
    }
  ],
