# inventory service
NAME=inventory

# /metrics endpoint
METRICS_PORT=9102

# migrations
MIGRATIONS_DIR=.

# postgres (deploy/docker-compose.yml → saga-pg-inventory)
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASS=postgres
DB_NAME=inventory
DB_SCHEMA=public

# outbox relay
OUTBOX_RELAY_POLL_INTERVAL=1s
OUTBOX_RELAY_BATCH_SIZE=50

# outbox kafka producer
OUTBOX_PRODUCER_BROKERS=localhost:19092
OUTBOX_PRODUCER_AUTH_ENABLED=false

# consumer: reserve.command / release.command
COMMANDS_CONSUMER_BROKERS=localhost:19092
COMMANDS_CONSUMER_TOPIC=saga.inventory.commands
COMMANDS_CONSUMER_GROUP_ID=inventory.commands
COMMANDS_CONSUMER_MAX_WAIT=50
COMMANDS_CONSUMER_AUTH_ENABLED=false
