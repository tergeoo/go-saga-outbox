# orchestrator service
ORCHESTRATOR_NAME=orchestrator

# HTTP
SERVER_PORT=8086
SERVER_TIMEOUT=30s

# migrations
MIGRATIONS_DIR=.

# scheduler tick interval (re-publish stuck commands)
REPUBLISHER_INTERVAL=1s

# postgres (deploy/docker-compose.yml → saga-pg-orchestrator)
DB_HOST=localhost
DB_PORT=5439
DB_USER=postgres
DB_PASS=postgres
DB_NAME=orchestrator
DB_SCHEMA=public

# outbox relay
OUTBOX_RELAY_POLL_INTERVAL=1s
OUTBOX_RELAY_BATCH_SIZE=50

# outbox kafka producer
OUTBOX_PRODUCER_BROKERS=localhost:19092
OUTBOX_PRODUCER_AUTH_ENABLED=false

# consumer: events from inventory
INVENTORY_CONSUMER_BROKERS=localhost:19092
INVENTORY_CONSUMER_TOPIC=saga.inventory.events
INVENTORY_CONSUMER_GROUP_ID=orchestrator.inventory.events
INVENTORY_CONSUMER_MAX_WAIT=50
INVENTORY_CONSUMER_AUTH_ENABLED=false

# consumer: events from payment
PAYMENT_CONSUMER_BROKERS=localhost:19092
PAYMENT_CONSUMER_TOPIC=saga.payment.events
PAYMENT_CONSUMER_GROUP_ID=orchestrator.payment.events
PAYMENT_CONSUMER_MAX_WAIT=50
PAYMENT_CONSUMER_AUTH_ENABLED=false

# consumer: events from notification
NOTIFICATION_CONSUMER_BROKERS=localhost:19092
NOTIFICATION_CONSUMER_TOPIC=saga.notification.events
NOTIFICATION_CONSUMER_GROUP_ID=orchestrator.notification.events
NOTIFICATION_CONSUMER_MAX_WAIT=50
NOTIFICATION_CONSUMER_AUTH_ENABLED=false