# payment service
PAYMENT_NAME=payment

# /metrics endpoint
METRICS_PORT=9101

# migrations
MIGRATIONS_DIR=.

# postgres (deploy/docker-compose.yml → saga-pg-payment)
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASS=postgres
DB_NAME=payment
DB_SCHEMA=public

# outbox relay
OUTBOX_RELAY_POLL_INTERVAL=1s
OUTBOX_RELAY_BATCH_SIZE=50

# outbox kafka producer
OUTBOX_PRODUCER_BROKERS=localhost:19092
OUTBOX_PRODUCER_AUTH_ENABLED=false

# consumer: charge.command / refund.command
COMMANDS_CONSUMER_BROKERS=localhost:19092
COMMANDS_CONSUMER_TOPIC=saga.payment.commands
COMMANDS_CONSUMER_GROUP_ID=payment.commands
COMMANDS_CONSUMER_MAX_WAIT=50
COMMANDS_CONSUMER_AUTH_ENABLED=false
